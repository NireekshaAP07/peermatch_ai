# Root .gitignore for PeerMatch AI

# Dependencies
node_modules/
venv/
.venv/
env/
__pycache__/
*.pyc
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/

# Build outputs
.next/
dist/
build/
out/
*.tsbuildinfo
next-env.d.ts

# Database
*.db
*.sqlite3

# Logs and PID
*.log
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDEs
.vscode/
.idea/
.DS_Store
*.pem

# Environment variables
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel
